APP_NAME=CourtMaster
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://courtmaster.yourdomain.com
APP_LOCALE=en
APP_TIMEZONE=UTC

# ─── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=courtmaster
DB_USERNAME=courtmaster_user
DB_PASSWORD=your_secure_password

# ─── Cache & Session ───────────────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=s3

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@courtmaster.yourdomain.com
MAIL_FROM_NAME="CourtMaster"

# ─── Broadcasting (Pusher / WebSockets) ────────────────────────────────────────
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_app_key
PUSHER_APP_SECRET=your_pusher_app_secret
PUSHER_APP_CLUSTER=ap1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ─── Payment Gateways ──────────────────────────────────────────────────────────
PAYMONGO_SECRET_KEY=sk_test_your_paymongo_key
PAYMONGO_PUBLIC_KEY=pk_test_your_paymongo_key
PAYMONGO_WEBHOOK_SECRET=your_paymongo_webhook_secret

STRIPE_KEY=pk_test_your_stripe_key
STRIPE_SECRET=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

GCASH_MERCHANT_ID=
MAYA_API_KEY=

# ─── Social Login (Socialite) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

# ─── SMS (Semaphore) ───────────────────────────────────────────────────────────
SMS_DRIVER=semaphore
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=CourtMaster

# ─── Storage ────────────────────────────────────────────────────────────────────
# Use "public" for the local disk, or "s3" for any S3-compatible object store.
FILESYSTEM_DISK=s3
# Generated reports stay private regardless of the active disk above.
FILESYSTEM_PRIVATE_DISK=local
# Court photos (Spatie Media Library) follow the active disk.
MEDIA_DISK=s3

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=courtmaster-assets
# Leave AWS_URL blank to auto-build URLs from the endpoint/bucket.
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
#
# The "s3" disk speaks the S3 API, so the SAME settings work for every major
# object store — only endpoint / region / path-style differ. Pick one:
#
#   AWS S3            AWS_ENDPOINT=            (leave blank)
#                     AWS_DEFAULT_REGION=ap-southeast-1
#                     AWS_USE_PATH_STYLE_ENDPOINT=false
#
#   Vultr Object Storage
#                     AWS_ENDPOINT=https://sgp1.vultrobjects.com
#                     AWS_DEFAULT_REGION=sgp1
#                     AWS_USE_PATH_STYLE_ENDPOINT=false
#
#   Cloudflare R2     AWS_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#                     AWS_DEFAULT_REGION=auto
#                     AWS_USE_PATH_STYLE_ENDPOINT=true
#
#   DigitalOcean Spaces
#                     AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
#                     AWS_DEFAULT_REGION=sgp1
#                     AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single,slack
LOG_SLACK_WEBHOOK_URL=
LOG_LEVEL=warning

# ─── Slack Notifications ───────────────────────────────────────────────────────
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=#courtmaster-alerts

# ─── Scout / Search ────────────────────────────────────────────────────────────
SCOUT_DRIVER=null

# ─── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_2FA=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_PWA=true

# ─── Sanctum ───────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=courtmaster.yourdomain.com

# ─── Queue / Horizon (optional) ────────────────────────────────────────────────
HORIZON_BASIC_AUTH_USERNAME=horizon
HORIZON_BASIC_AUTH_PASSWORD=your_horizon_password
